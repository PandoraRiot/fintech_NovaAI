# ══════════════════════════════════════════════════════════════════════════════
# FinTech Intelligence MVP — Variables de entorno
# Copia: cp .env.example .env  y edita los valores
# ══════════════════════════════════════════════════════════════════════════════

# ── 🦙 AGENTE: LLaMA 3.2 1B (PRIORIDAD 1) ───────────────────────────────────
# URL base del endpoint OpenAI-compatible de tu cluster vLLM/Ollama
# Ejemplos:
#   Ollama local:      http://localhost:11434
#   vLLM en cluster:   http://192.168.x.x:8000   o   http://tu-cluster.internal:8080
#   LM Studio:         http://localhost:1234
#
# ⚠️  IMPORTANTE: Si este valor está vacío, el agente usa Claude o modo offline.
LLAMA_BASE_URL=

# Nombre del modelo tal como aparece en tu servidor.
# Ollama:  llama3.2:1b       o   llama3.2:3b
# vLLM:    deqing/fone-llama-3.2-1B-fineweb-sample-100BT-fone3d-hybrid-tile-v4
#          (o el alias que le hayas puesto al modelo en el servidor)
LLAMA_MODEL=llama3.2:1b

# ── 🤖 AGENTE: Claude API (PRIORIDAD 2 — fallback si LLaMA no responde) ──────
# Si no tienes key, el agente usa modo offline por reglas determinísticas.
ANTHROPIC_API_KEY=

# ── 🗄️  BASE DE DATOS (PostgreSQL) ────────────────────────────────────────────
POSTGRES_USER=fintech
POSTGRES_PASSWORD=fintech123
POSTGRES_DB=fintechdb

# ── ⚙️  FEATURE FLAGS ──────────────────────────────────────────────────────────
# Desactivar si no tienes conexión a internet en el entorno de demo
ENABLE_GEO_ENRICHMENT=true
ENABLE_FX_ENRICHMENT=true
ENABLE_DB_PERSISTENCE=true

# ── 📊 PARÁMETROS ML ──────────────────────────────────────────────────────────
KMEANS_K=4
ISOLATION_FOREST_CONTAMINATION=0.07
